# ── Centro de Mando JC — variables de entorno (configúralas en Coolify) ──

# Token que valida los heartbeats entrantes. DEBE coincidir con el
# JC_MONITOR_TOKEN que pongas en el .env de cada cliente (main.py).
# Genera uno largo, p.ej.:  openssl rand -hex 24
INGEST_TOKEN=cambia_esto_por_un_token_largo_y_secreto

# Acceso al panel web (HTTP Basic Auth)
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esta_contraseña

# Minutos sin heartbeat para marcar un cliente como offline
# (regla práctica: ~3x el intervalo de reporte del cliente)
OFFLINE_AFTER_MIN=45

# Carpeta del SQLite. En Coolify monta un volumen persistente en /data.
DATA_DIR=/data

# Puerto HTTP interno del contenedor
PORT=8090
